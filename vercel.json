{
  "version": 2,
  "builds": [
    {
      "src": "packages-frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "packages-backend/server.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "packages-backend/server.ts"
    },
    {
      "src": "/(.*?)\\.(js|css|png|jpg|jpeg|svg|ico|json|woff|woff2)",
      "dest": "packages-frontend/$1.$2"
    },
    {
      "src": "/(.*)",
      "dest": "packages-frontend/index.html"
    }
  ]
}